# Transcription — AssemblyAI provider (default, fast/cheap)
ASSEMBLYAI_API_KEY=

# Transcription — Gemini native audio (alternative, better for merged speakers)
# Visual analysis (mi analyze) also uses GEMINI_API_KEY
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-pro-preview             # visual analysis model; verify at https://ai.google.dev/gemini-api/docs/models
GEMINI_TRANSCRIPTION_MODEL=gemini-2.5-pro       # transcription model (Pro for quality, Flash for cost)

# Transcription — local Whisper + pyannote.audio (requires `uv pip install whisperx torch`)
# Accept terms at https://huggingface.co/pyannote/speaker-diarization-3.1 first.
HF_TOKEN=

# Note: Claude auth is handled by Claude Code / Claude.ai. Scripts never call Anthropic directly.
